# MongoDB Atlas connection string
# Get this from: mongodb.com/atlas → Connect → Drivers → Python
MONGODB_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ummaahpro?retryWrites=true&w=majority

# JWT Secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# OpenAI API key
OPENAI_API_KEY=sk-your-openai-key-here

# Server port (default 8000)
PORT=8000
